# Git LFS tracking for large binary files
# NOTE: To apply LFS to EXISTING tracked files, run:
#       git lfs migrate import --include="*.db,*.joblib,*.mp4,*.msi,*.elf,*.quarantined,*.sha256.txt,full.csv/**"
#       This REWRITES history — coordinate with team before running.
#
# The rules below apply ONLY to NEW files added after this commit.
# Existing tracked files remain as-is until migration is run.

# Database & hash stores (new files only)
*.db filter=lfs diff=lfs merge=lfs -text
# ML model artifacts (new files only)
*.joblib filter=lfs diff=lfs merge=lfs -text
*.pkl filter=lfs diff=lfs merge=lfs -text
*.pickle filter=lfs diff=lfs merge=lfs -text
# Quarantine / malware samples (new files only)
*.quarantined filter=lfs diff=lfs merge=lfs -text
*.elf filter=lfs diff=lfs merge=lfs -text
# Media & installers (new files only)
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.msi filter=lfs diff=lfs merge=lfs -text
# Large text datasets (new files only)
*.sha256.txt filter=lfs diff=lfs merge=lfs -text
full.csv/** filter=lfs diff=lfs merge=lfs -text
